{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/subscribe.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/subscribe", "dest": "/api/subscribe" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
