{
  "version": 2,
  "builds": [
    {
      "src": "api/subscribe.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/subscribe", "dest": "/api/subscribe" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
